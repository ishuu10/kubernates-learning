pipeline {
    agent any

    tools {
        nodejs 'NodeJS'
    }

    stages {
        stage('Debug') {
            steps {
                sh '''
                    echo "PATH=$PATH"
                    which node || true
                    which npm || true
                    node -v || true
                    npm -v || true
                    ls -R $NODEJS_HOME || true
                '''
            }
        }
    }
}